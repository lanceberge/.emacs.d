;; Emacs setup w/ no plugins -- i use this in the terminal only
(menu-bar-mode -1)
(tool-bar-mode -1)
(scroll-bar-mode -1)

(setq make-backup-files nil
      auto-save-default nil
      create-lockfiles nil)

(setq
 inhibit-startup-screen t
 initial-scratch-message nil
 ring-bell-function 'ignore
 confirm-kill-emacs 'y-or-n-p
 visible-bell nil
 use-short-answers t
 delete-by-moving-to-trash t
 sentence-end-double-space nil
 tab-width 4
 indent-tabs-mode nil
 fill-column 90
 scroll-conservatively 1000
 scroll-margin 2
 scroll-preserve-screen-position t
 kill-whole-line t
 confirm-kill-emacs nil)

(line-number-mode 1)
(column-number-mode 1)
(electric-pair-mode 1)

(if (fboundp 'icomplete-vertical-mode)
    (progn
      (fido-mode 1)
      (icomplete-vertical-mode 1)
      (define-key completion-in-region-mode-map (kbd "M-n")
                  #'minibuffer-next-completion)
      (define-key completion-in-region-mode-map (kbd "M-p")
                  #'minibuffer-previous-completion))
  (ido-mode 1))
(recentf-mode)

(if (fboundp 'completion-preview-mode)
    (progn
      (add-hook 'prog-mode-hook 'completion-preview-mode)
      (add-hook 'text-mode-hook 'completion-preview-mode)))

(setq shift-select-mode t)
(transient-mark-mode 1)

(set-language-environment "UTF-8")
(prefer-coding-system 'utf-8-unix)
(set-default-coding-systems 'utf-8-unix)
(set-terminal-coding-system 'utf-8-unix)
(set-keyboard-coding-system 'utf-8-unix)

(setq ido-enable-flex-matching t
      ido-auto-merge-work-directories-length -1
      ido-use-filename-at-point 'guess
      ido-use-virtual-buffers t
      ido-default-buffer-method 'selected-window
      ido-confirm-unique-completion nil
      ido-use-faces t)

(setq ido-vertical-define-keys 'C-n-C-p-up-and-down
      ido-vertical-show-count t)

(setq completion-cycle-threshold 3
      completions-detailed t
      completions-format 'one-column
      completions-header-format nil
      completions-max-height 15)

(global-set-key (kbd "C-x k") 'kill-current-buffer)

(defun reload-init-file ()
  (interactive)
  (load-file user-init-file))

(defun switch-to-other-buffer ()
  (interactive)
  (switch-to-buffer (other-buffer)))

(defun window-other-previous ()
  "Move to the previous window, splitting the frame first when needed."
  (interactive)
  (if (one-window-p)
      (split-window-sensibly)
    (other-window -1)))

(global-set-key (kbd "M-s r") 'recentf)
(global-set-key (kbd "M-s f") 'project-find-file)
(global-set-key (kbd "M-s g") 'project-find-regexp)
(global-set-key (kbd "C-c r") 'reload-init-file)
(global-set-key (kbd "C-c l") 'switch-to-other-buffer)
(global-set-key (kbd "C-c d") 'duplicate-line)
(global-set-key (kbd "C-c k") 'project-switch-project)
(global-set-key (kbd "M-o") 'other-window)
(global-set-key (kbd "M-O") 'other-window-previous)

(load-theme 'tango-dark t)
